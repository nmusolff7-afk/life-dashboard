# Anthropic Claude API key — required for all AI features (meal estimation, scanning, plans).
ANTHROPIC_API_KEY=

# Flask session-cookie signing key. Required in production (crash on boot if missing); dev uses an ephemeral random key.
SECRET_KEY=

# HMAC secret for signing JWT bearer tokens used by the React Native client. Falls back to SECRET_KEY if unset.
JWT_SECRET=

# Comma-separated allowed origins for /api/* CORS. Default covers Expo dev servers (8081, 19000, 19006).
CORS_ORIGINS=

# Path to the SQLite database file. Default: life_dashboard.db in the working directory.
DB_PATH=

# HTTP port the dev server binds to (python app.py). Default: 5000.
PORT=

# Server-side secret required to authorize password resets via POST /api/reset-password. Reset is disabled if unset.
RECOVERY_KEY=

# Public base URL of this Flask app (e.g. https://apex.up.railway.app). Used to build OAuth redirect URIs.
APP_URL=

# Google OAuth client ID for the Gmail integration. Gmail features are disabled if unset.
GOOGLE_CLIENT_ID=

# Google OAuth client secret for the Gmail integration. Gmail features are disabled if unset.
GOOGLE_CLIENT_SECRET=
